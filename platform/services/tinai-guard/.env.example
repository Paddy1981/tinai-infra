# ── Cloud API ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://guard:changeme@postgres:5432/tinai_guard
REDIS_URL=redis://redis:6379/0
SECRET_KEY=change-this-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── Object Storage (MinIO) ─────────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
MINIO_SECURE=false

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Headscale ─────────────────────────────────────────────────────────────────
HEADSCALE_URL=http://headscale:8080
HEADSCALE_API_KEY=changeme

# ── Cloudflare (optional, for Tunnel) ─────────────────────────────────────────
CLOUDFLARE_TUNNEL_TOKEN=

# ── Edge device .env ──────────────────────────────────────────────────────────
# Copy these values from the provision output
CLOUD_WEBHOOK_URL=https://guard.tinai.cloud/api/v1
TENANT_ID=
SITE_ID=
HS_AUTH_KEY=

# Edge-specific toggles
FEATURE_MAC_PERSISTENCE=false
WIFI_IFACE=wlan1
LOITER_MINUTES=5
CROWD_THRESHOLD=20

# Optional GPS/battery reporting
GPS_LAT=
GPS_LON=
BATTERY_PCT=
SIGNAL_RSSI=

# .env.example
# Copy to .env for local development.
# DO NOT commit .env to git.

# ── Required ──────────────────────────────────────────────────────────────────
LAGO_API_KEY=your-lago-api-key-here

# ── Prometheus ────────────────────────────────────────────────────────────────
# For local dev, port-forward Prometheus:
#   kubectl port-forward svc/prometheus-server 9090:9090 -n monitoring
PROMETHEUS_URL=http://localhost:9090

# ── Lago ──────────────────────────────────────────────────────────────────────
# For local dev, port-forward Lago:
#   kubectl port-forward svc/lago-api 3000:3000 -n billing
LAGO_API_URL=http://localhost:3000

# ── NATS ──────────────────────────────────────────────────────────────────────
# For local dev, port-forward NATS:
#   kubectl port-forward svc/nats 4222:4222 -n core
NATS_SERVERS=nats://localhost:4222

# ── Schedule ──────────────────────────────────────────────────────────────────
# Short interval for dev/testing (2 minutes)
METERING_INTERVAL_MS=120000
METERING_LOOKBACK_MS=180000

# ── Tenant namespaces ─────────────────────────────────────────────────────────
TENANT_NS_PREFIX=tenant-
EXCLUDE_NAMESPACES=kube-system,kube-public,monitoring,cert-manager,argo,core,billing

# ── Debug ─────────────────────────────────────────────────────────────────────
LOG_LEVEL=debug
PORT=3100
NODE_ENV=development
ADMIN_TOKEN=dev-token-unsafe

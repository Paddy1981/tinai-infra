# TinAI Pipelines - Woodpecker Server Configuration

WOODPECKER_HOST=https://pipelines.tinai.cloud
WOODPECKER_ADMIN=tinai-admin
WOODPECKER_OPEN=false
WOODPECKER_AUTHENTICATE_PUBLIC_REPOS=true
WOODPECKER_LOG_LEVEL=info
WOODPECKER_SERVER_ADDR=:8000
WOODPECKER_GRPC_ADDR=:9000

# Forgejo OAuth Integration (filled at deploy time via K8s secret)
WOODPECKER_GITEA=true
WOODPECKER_GITEA_URL=https://repos.tinai.cloud
WOODPECKER_GITEA_CLIENT=${WOODPECKER_GITEA_CLIENT}
WOODPECKER_GITEA_SECRET=${WOODPECKER_GITEA_SECRET}

# Database
WOODPECKER_DATABASE_DRIVER=postgres
WOODPECKER_DATABASE_DATASOURCE=postgres://woodpecker:${DB_PASSWORD}@postgres.default.svc.cluster.local:5432/woodpecker?sslmode=require

# Security
WOODPECKER_AGENT_SECRET=${AGENT_SECRET}
WOODPECKER_ENCRYPTION_TLS_CERT=/etc/certs/tinai.crt
WOODPECKER_ENCRYPTION_TILS_KEY=/etc/certs/tinai.key

# Build settings
WOODPECKER_MAX_PROCS=0
WOODPECKER_PIPELINE_LIMITS_MEMORY_SWAP=-1
WOODPECKER_PIPELINE_LIMITS_MEMORY=512000000
WOODPECKER_PIPELINE_LIMITS_CPUS=1.0
WOODPECKER_PIPELINE_LIMITS_CPU_QUOTA=100000
WOODPECKER_PIPELINE_LIMITS_CPU_SHARES=1024

# Webhook
WOODPECKER_WEBHOOK_SKIP_VERIFY=false

# Metrics
WOODPECKER_METRICS_SERVER_ADDR=:9091

# Container runtime
WOODPECKER_BACKEND_DOCKER_HOST=unix:///var/run/docker.sock
WOODPECKER_BACKEND_DOCKER_NETWORK=tinai-net

# Cleanup
WOODPECKER_CLEANUP_INTERVAL=24h
WOODPECKER_CLEANUP_DISABLE_ON_SCHEDULE=false

# Privileged settings
WOODPECKER_DOCKER_PRIVILEGED=false

# Volume mounts
WOODPECKER_DOCKER_VOLUMES=/var/run/docker.sock:/var/run/docker.sock

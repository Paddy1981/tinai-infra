# TinAI Insights Grafana Configuration Patch
# Apply this configuration to override Grafana defaults

[server]
domain = insights.tinai.cloud
root_url = https://insights.tinai.cloud
serve_from_sub_path = false
enable_gzip = true
enable_https = true
protocol = http

[security]
cookie_secure = true
cookie_samesite = lax
cookie_name = tinai_grafana_session
allow_embedding = true
strict_transport_security = true
strict_transport_security_max_age_seconds = 31536000
content_security_policy = true
content_security_policy_report_only = false
angular_support_enabled = true
token_expiration_minutes = 1440

[users]
default_theme = dark
default_language = en-US
home_page = /d/tinai-overview/tinai-overview
login_hint = admin
password_validation_enabled = true
password_min_length = 12
password_validation_message = Password must be at least 12 characters with uppercase, lowercase, numbers and symbols
auto_assign_org = false
auto_assign_org_id = 1
auto_assign_org_role = Viewer

[auth]
login_maximum_inactive_lifetime_duration = 7d
login_maximum_lifetime_duration = 30d
token_rotation_attack_prevention_enabled = true
disable_login_form = false
disable_signout_menu = false
oauth_auto_login = false
disable_abando = false
signout_redirect_url = /login

[auth.generic_oauth]
enabled = false
name = OAuth
allow_sign_up = false
auto_login = false

[dashboards]
default_home_dashboard_path = /etc/grafana/provisioning/dashboards/tinai-overview.json
versions_to_keep = 20
min_refresh_interval = 10s

[datasources]
uid_prefix = tinai_

[feature_toggles]
enable = ngalert,publicDashboards,disableSecretsUI,recordedQueries,logRequestsInstrumentationEnabled

[branding]
login_logo = public/img/tinai-logo.svg
login_background = public/img/login-background.jpg
app_title = TinAI Insights
login_subtitle = TinAI Cloud Platform
login_box_background_fill_color = linear-gradient(135deg, #0F172A 0%, #1E293B 100%)
help_title = TinAI Insights Help
help_url = https://docs.tinai.cloud/insights
menu_links =
side_menu_opacity = 1
side_menu_dark = true
footer_link_target = _blank
footer_links = TinAI Cloud|https://tinai.cloud,Documentation|https://docs.tinai.cloud,Status|https://status.tinai.cloud

[explore]
enabled = true

[profiling]
enabled = true

[analytics]
reporting_enabled = false
google_analytics_ua_id =
segment_io_key =
check_for_updates = false

[alerting]
enabled = true
execute_alerts = true

[unified_alerting]
enabled = true
state_history_settings = { state_history_settings }

[log]
mode = console file
level = info
log_rotate = true
max_lines = 1000000
max_size_mb = 100
daily_rotate = true
max_days = 7

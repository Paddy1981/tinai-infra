{
  "name": "@tinai/client",
  "version": "0.1.0",
  "description": "TypeScript client SDK for the Tinai Cloud Platform",
  "author": "Tinai",
  "license": "MIT",
  "homepage": "https://tinai.cloud",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Paddy1981/tinai-js.git"
  },
  "keywords": [
    "tinai",
    "realtime",
    "websocket",
    "authentication",
    "sdk",
    "typescript",
    "supabase-alternative"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.10",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "ws": "^8.17.0"
  },
  "peerDependencies": {
    "ws": "^8.0.0"
  },
  "peerDependenciesMeta": {
    "ws": {
      "optional": true
    }
  }
}

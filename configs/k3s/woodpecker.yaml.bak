---
# Namespaces
apiVersion: v1
kind: Namespace
metadata:
  name: woodpecker
  labels:
    app.kubernetes.io/part-of: tinai-ci
---
apiVersion: v1
kind: Namespace
metadata:
  name: tinai-build
  labels:
    app.kubernetes.io/part-of: tinai-ci
---
# Woodpecker secrets — OAuth creds + agent shared secret.
# Replace placeholders after creating the Forgejo OAuth app.
# Generate agent secret: openssl rand -hex 32
apiVersion: v1
kind: Secret
metadata:
  name: woodpecker-secrets
  namespace: woodpecker
type: Opaque
stringData:
  WOODPECKER_GITEA_CLIENT: "REPLACE_WITH_OAUTH_CLIENT_ID"
  WOODPECKER_GITEA_SECRET: "REPLACE_WITH_OAUTH_CLIENT_SECRET"
  WOODPECKER_AGENT_SECRET: "REPLACE_WITH_AGENT_SECRET"
---
# Woodpecker Server — SQLite (no external DB needed for single-node)
apiVersion: apps/v1
kind: Deployment
metadata:
  name: woodpecker-server
  namespace: woodpecker
  labels:
    app: woodpecker-server
spec:
  replicas: 1
  selector:
    matchLabels:
      app: woodpecker-server
  template:
    metadata:
      labels:
        app: woodpecker-server
    spec:
      nodeSelector:
        tinai.cloud/role: stateful
      containers:
        - name: server
          image: woodpeckerci/woodpecker-server:v3.13.0
          ports:
            - containerPort: 8000
              hostPort: 8000
              name: http
            - containerPort: 9000
              name: grpc
          envFrom:
            - secretRef:
                name: woodpecker-secrets
          env:
            - name: WOODPECKER_OPEN
              value: "false"
            - name: WOODPECKER_HOST
              value: "http://localhost:8000"
            - name: WOODPECKER_GITEA
              value: "true"
            - name: WOODPECKER_GITEA_URL
              value: "http://forgejo.tinai-system.svc.cluster.local:3000"
            - name: WOODPECKER_ADMIN
              value: "tinai-admin"
            - name: WOODPECKER_DATABASE_DRIVER
              value: "sqlite3"
            - name: WOODPECKER_DATABASE_DATASOURCE
              value: "/var/lib/woodpecker/woodpecker.sqlite"
            - name: WOODPECKER_LIMIT_REPOS
              value: "0"
            - name: WOODPECKER_DEFAULT_PIPELINE_TIMEOUT
              value: "60"
            - name: WOODPECKER_PLUGINS_PRIVILEGED
              value: ""
            - name: WOODPECKER_LOG_LEVEL
              value: "info"
          volumeMounts:
            - name: data
              mountPath: /var/lib/woodpecker
          resources:
            requests:
              cpu: 100m
              memory: 256Mi
            limits:
              cpu: 500m
              memory: 512Mi
          readinessProbe:
            httpGet:
              path: /healthz
              port: 8000
            initialDelaySeconds: 15
            periodSeconds: 10
          livenessProbe:
            httpGet:
              path: /healthz
              port: 8000
            initialDelaySeconds: 30
            periodSeconds: 30
      volumes:
        - name: data
          emptyDir: {}
---
apiVersion: v1
kind: Service
metadata:
  name: woodpecker-server
  namespace: woodpecker
spec:
  selector:
    app: woodpecker-server
  ports:
    - name: http
      port: 8000
      targetPort: 8000
    - name: grpc
      port: 9000
      targetPort: 9000
---
# Woodpecker Agent — Kubernetes backend, builds run in tinai-build namespace
apiVersion: v1
kind: ServiceAccount
metadata:
  name: woodpecker-agent
  namespace: woodpecker
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: woodpecker-agent
  namespace: woodpecker
  labels:
    app: woodpecker-agent
spec:
  replicas: 1
  selector:
    matchLabels:
      app: woodpecker-agent
  template:
    metadata:
      labels:
        app: woodpecker-agent
    spec:
      serviceAccountName: woodpecker-agent
      containers:
        - name: agent
          image: woodpeckerci/woodpecker-agent:v3.13.0
          envFrom:
            - secretRef:
                name: woodpecker-secrets
          env:
            - name: WOODPECKER_SERVER
              value: "woodpecker-server.woodpecker.svc.cluster.local:9000"
            - name: WOODPECKER_MAX_WORKFLOWS
              value: "4"
            - name: WOODPECKER_BACKEND
              value: "kubernetes"
            - name: WOODPECKER_BACKEND_K8S_NAMESPACE
              value: "tinai-build"
            - name: WOODPECKER_BACKEND_K8S_STORAGE_CLASS
              value: "local-path"
            - name: WOODPECKER_BACKEND_K8S_STORAGE_RWX
              value: "false"
            - name: WOODPECKER_BACKEND_K8S_SERVICE_ACCOUNT_NAME
              value: "woodpecker-pipeline"
            - name: WOODPECKER_LOG_LEVEL
              value: "info"
          resources:
            requests:
              cpu: 100m
              memory: 128Mi
            limits:
              cpu: 1000m
              memory: 512Mi
---
# RBAC: Agent needs to manage pods in tinai-build namespace
apiVersion: rbac.authorization.k8s.io/v1
kind: Role
metadata:
  name: woodpecker-agent
  namespace: tinai-build
rules:
  - apiGroups: [""]
    resources: ["pods", "pods/log", "secrets", "configmaps", "persistentvolumeclaims"]
    verbs: ["get", "list", "watch", "create", "update", "patch", "delete"]
  - apiGroups: ["apps"]
    resources: ["deployments"]
    verbs: ["get", "list"]
---
apiVersion: rbac.authorization.k8s.io/v1
kind: RoleBinding
metadata:
  name: woodpecker-agent
  namespace: tinai-build
subjects:
  - kind: ServiceAccount
    name: woodpecker-agent
    namespace: woodpecker
roleRef:
  kind: Role
  name: woodpecker-agent
  apiGroup: rbac.authorization.k8s.io
---
# Pipeline ServiceAccount — used by build pods in tinai-build
apiVersion: v1
kind: ServiceAccount
metadata:
  name: woodpecker-pipeline
  namespace: tinai-build
---
# Pipeline pods can patch deployments in tinai-apps (where the 8 apps live)
apiVersion: rbac.authorization.k8s.io/v1
kind: Role
metadata:
  name: woodpecker-pipeline-deploy
  namespace: tinai-apps
rules:
  - apiGroups: ["apps"]
    resources: ["deployments"]
    verbs: ["get", "list", "watch", "patch", "update"]
  - apiGroups: [""]
    resources: ["pods", "pods/log"]
    verbs: ["get", "list", "watch"]
---
apiVersion: rbac.authorization.k8s.io/v1
kind: RoleBinding
metadata:
  name: woodpecker-pipeline-deploy
  namespace: tinai-apps
subjects:
  - kind: ServiceAccount
    name: woodpecker-pipeline
    namespace: tinai-build
roleRef:
  kind: Role
  name: woodpecker-pipeline-deploy
  apiGroup: rbac.authorization.k8s.io
---
# Pipeline pods also need deploy access to tinai-system (for core services)
apiVersion: rbac.authorization.k8s.io/v1
kind: Role
metadata:
  name: woodpecker-pipeline-deploy
  namespace: tinai-system
rules:
  - apiGroups: ["apps"]
    resources: ["deployments"]
    verbs: ["get", "list", "watch", "patch", "update"]
  - apiGroups: [""]
    resources: ["pods", "pods/log"]
    verbs: ["get", "list", "watch"]
---
apiVersion: rbac.authorization.k8s.io/v1
kind: RoleBinding
metadata:
  name: woodpecker-pipeline-deploy
  namespace: tinai-system
subjects:
  - kind: ServiceAccount
    name: woodpecker-pipeline
    namespace: tinai-build
roleRef:
  kind: Role
  name: woodpecker-pipeline-deploy
  apiGroup: rbac.authorization.k8s.io
